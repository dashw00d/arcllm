# GhostGraph Environment Configuration
# Copy to .env and fill in values

# --- Required ---
REDIS_URL=redis://localhost:6379
POSTGRES_URL=postgresql://ghostgraph:ghostgraph@localhost:5432/ghostgraph

# --- LLM (required for exploration/schema) ---
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5-20250929

# --- Networking / Stealth ---
# Auto-detected on Vultr VPS; leave empty for local dev
IPV6_SUBNET=
# light = curl_cffi only | handoff = Camoufox cookies -> curl_cffi | full = browser automation
SCRAPING_MODE=handoff

# --- Fleet Management ---
VULTR_API_KEY=
GITHUB_DEPLOY_KEY=
API_BASE_URL=http://localhost:8000

# --- Postgres Connection Pool ---
DB_POOL_MIN=1
DB_POOL_MAX=3

# --- Task Defaults ---
DEFAULT_DEADLINE_MINUTES=30

# --- Stealth Tuning ---
# TIMEOUT_CHAIN=[5,10,15]
# MAX_403_ROTATIONS=5
# COOKIE_CACHE_TTL=1500
# DEFAULT_RPM=45
# CLOUDFLARE_RPM=30
# AKAMAI_RPM=20

# --- Circuit Breaker ---
# CIRCUIT_BREAKER_WINDOW=20
# CIRCUIT_BREAKER_THRESHOLD=0.6

# --- Backpressure ---
# STREAM_SOFT_LIMIT=500
# STREAM_HARD_LIMIT=1000

# --- API Security ---
# Set true for internet-facing deployments
API_REQUIRE_KEYS=true
# Optional bootstrap key inserted at startup (rotate/remove after first use)
BOOTSTRAP_API_KEY=

# --- Schema ---
# SCHEMA_CACHE_TTL_DAYS=14
# SCHEMA_SAMPLE_COUNT=3
