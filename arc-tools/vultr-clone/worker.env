# Vultr clone worker environment
# Mirrors cloud worker config but with SPOOF_IPV6=true

# IPv6 spoofing — exercises rotation code but doesn't bind
SPOOF_IPV6=true
IPV6_SUBNET=2001:db8:test:1234::/64

# Henry (local LLM)
HENRY_URL=http://localhost:11435/v1/chat/completions
HENRY_MODEL=qwen35

# Services (host network mode — all on localhost)
POSTGRES_URL=postgresql://temporal:temporal@localhost:5432/ghostgraph
REDIS_URL=redis://localhost:6379
TEMPORAL_HOST=localhost:7233
