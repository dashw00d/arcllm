#compdef arcllm

_arcllm() {
  local -a commands
  commands=(
    'start:Start the ArcLLM user service'
    'stop:Stop the ArcLLM user service'
    'restart:Restart the ArcLLM user service'
    'status:Show service and worker health'
    'logs:Show service logs'
    'models:List served models'
    'health:Show router health'
    'chat:Send a chat prompt'
    'env:Print OpenAI-compatible environment exports'
    'config:Print current config'
    'set:Set a config key'
    'set-model:Set the current model'
    'completions:Print shell completion scripts'
    'serve:Run the cluster in the foreground'
  )

  local -a config_keys
  config_keys=(
    MODEL_ID
    TORCH_DTYPE
    API_HOST
    ROUTER_PORT
    GPU_IDS
    WORKER_PORTS
    DEFAULT_MAX_NEW_TOKENS
    ENABLE_THINKING
  )

  local -a models
  models=(
    'Qwen/Qwen3-0.6B'
    'Qwen/Qwen3-1.7B'
    'Qwen/Qwen3-4B'
    'Qwen/Qwen3-8B'
    'Qwen/Qwen3.5-27B'
    'Qwen/Qwen3.5-35B-A3B'
  )

  case "$words[2]" in
    set-model)
      _arguments \
        '--no-restart[Update config without restarting the service]' \
        '1:model:->models'
      case $state in
        models) _describe -t models 'models' models ;;
      esac
      return
      ;;
    set)
      _arguments \
        '--no-restart[Update config without restarting the service]' \
        '1:key:->keys' \
        '2:value:->values'
      case $state in
        keys) _describe -t keys 'config keys' config_keys ;;
        values)
          case "$words[3]" in
            MODEL_ID) _describe -t models 'models' models ;;
            TORCH_DTYPE) _values 'dtype' float16 bfloat16 float32 ;;
            ENABLE_THINKING) _values 'thinking' true false ;;
          esac
          ;;
      esac
      return
      ;;
    chat)
      _arguments \
        '--model[Override the configured model]:model:->models' \
        '--max-tokens[Maximum new tokens]:tokens:' \
        '--temperature[Sampling temperature]:temperature:' \
        '1:prompt:_message "prompt"'
      case $state in
        models) _describe -t models 'models' models ;;
      esac
      return
      ;;
    logs)
      _arguments \
        '(-n --lines)'{-n,--lines}'[Number of log lines]:lines:' \
        '(-f --follow)'{-f,--follow}'[Follow logs]'
      return
      ;;
    completions)
      _values 'shell' bash zsh
      return
      ;;
  esac

  _describe -t commands 'arcllm commands' commands
}

_arcllm "$@"
